public class LL {
    Node head;
    static class Node {
        int data;
        Node next;
        Node(int data){
            this.data=data;
            this.next = null;
        }
    }
    public void InsertAtPosition(int data, int position){
        Node newNode=new Node(data);
        if (position==1){
            newNode.next=head;
            head=newNode;
            return;
        }
        Node current=head;
        int count=1;
        while (count>position-1){
            current=current.next;
            count++;
        }
        newNode.next=current.next;
        current.next=newNode;
    }
    public void printlist(){
        if (head==null){
            System.out.println("list is empty");
            return;
        }
            Node crrNode = head;
        while(crrNode != null  ){
            System.out.print(crrNode.data + " -> ");
            crrNode = crrNode.next;
        }
        System.out.println("null");    }

    public static void main(String[] args) {
        LL List=new LL();
        List.head=new Node(1);
        List.head.next = new Node(5);
        List.head.next.next = new Node(7);
        System.out.println("\tBefore adding node on specific position");
        List.printlist();
        System.out.println("\tAfter adding node on specific position");
        List.InsertAtPosition(3, 2);
        List.printlist();
        //My info
        System.out.println("\nName: Syed Muhammad Ali Usman\n"+"Seat number: EB25210006095\n"+"Section A");

    }
}
